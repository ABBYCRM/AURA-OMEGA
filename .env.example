# ============================================================================
# AURA-OMEGA — environment template
# ----------------------------------------------------------------------------
# Copy to `.env` (which is git-ignored) and fill in real values, OR set these
# in Render / Replit Secrets. NEVER commit real keys.
#
# In production these are pushed to Render via:
#   RENDER_API_KEY=... pnpm --filter @workspace/scripts run render:set-env
# ============================================================================

# ── Core (required for AI chat + browser tools) ─────────────────────────────
PORT=3000
NODE_ENV=development
# DATABASE_URL=postgres://user:pass@host:5432/db

# LLM gateway — all agent reasoning runs through OpenRouter
OPENROUTER_API_KEY=

# Browser automation (Steel) + default web search (Firecrawl)
STEEL_API_KEY=
FIRECRAWL_API_KEY=

# ── Buddy AI (NeuroBuddy) — extra persona endpoints ─────────────────────────
NEUROBUDDY_API_KEY=

# ── Buddy AI as an OpenAI-compatible FALLBACK LLM for the orchestrator ───────
# When the primary OpenRouter call fails and these are set, the agent loop
# falls back to this endpoint.
BUDDY_API_KEY=
BUDDY_BASE_URL=https://neurobuddy-wg8b.onrender.com/api/external/v1
BUDDY_MODEL=bos-omega

# ── Composio (authenticated SaaS/API tool router) ───────────────────────────
# Powers the composio_action agent tool. Execution stays OFF until you flip
# ALLOW_COMPOSIO_EXECUTE=true after connecting accounts in Composio.
COMPOSIO_API_KEY=
COMPOSIO_BASE_URL=https://backend.composio.dev/api/v3.1
ALLOW_COMPOSIO_EXECUTE=false

# ── Observability ───────────────────────────────────────────────────────────
# Helicone: when set, all OpenRouter traffic is transparently proxied through
# Helicone for logging/analytics (https://openrouter.helicone.ai/api/v1).
HELICONE_API_KEY=

# LangSmith (a.k.a. LangChain) tracing for LLM runs.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=aura-omega
# Optional overrides:
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_TRACING=true

# ── Web search providers (web_search tool fails over Tavily → Exa → Firecrawl) ─
TAVILY_API_KEY=
EXA_API_KEY=

# ── Semantic memory (real vector RAG for VAULT's memory_search) ──────────────
# Any OpenAI-compatible /embeddings endpoint. When unset, memory_search falls
# back to keyword matching.
EMBEDDINGS_API_KEY=
EMBEDDINGS_BASE_URL=https://api.openai.com/v1
EMBEDDINGS_MODEL=text-embedding-3-small

# ── Inngest (durable event bus) ─────────────────────────────────────────────
# INNGEST_EVENT_KEY is the trailing path segment of your ingest webhook URL:
#   https://inn.gs/e/<INNGEST_EVENT_KEY>
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── E2B (cloud code-interpreter sandbox; powers the cloud_code_exec tool) ────
# Requires the optional SDK: pnpm --filter @workspace/api-server add @e2b/code-interpreter
E2B_API_KEY=

# ── External inbound API (optional) ─────────────────────────────────────────
# If set, /api/external/v1/* requires this key (Bearer or x-api-key).
# AURA_OMEGA_API_KEY=

# Discord Bridge: UI -> API -> Discord -> AURA-OMEGA Runtime -> Discord -> UI
DISCORD_BRIDGE_ENABLED=true
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=
# Optional but recommended: comma-separated Discord user IDs for the Claw bot(s) whose replies should be accepted.
DISCORD_AURA_BOT_USER_IDS=
DISCORD_REPLY_WAIT_MS=90000
DISCORD_REPLY_POLL_MS=2000

# AURA-OMEGA MVP / n8n / autonomy controls
AURA_MAX_UPLOAD_MB=100
AURA_HEARTBEAT_LIVE=false
AURA_INTERNAL_AUTONOMY_DISABLED=false
AURA_INTERNAL_AUTONOMY_TICK_MS=60000
N8N_WEBHOOK_BASE_URL=
N8N_WEBHOOK_TOKEN=
N8N_WEBHOOK_RETRIES=2
N8N_WEBHOOK_TIMEOUT_MS=30000
N8N_LIVE_EXECUTION_DISABLED=false
AURA_SETTINGS_FILE=.aura-omega-settings.json
KIMI_API_KEY=
KIMI_BASE_URL=
KIMI_MODEL=kimi-k2.6
AURA_OMEGA_API_KEY=
